APP_NAME=Supplier Redaction API
REDACTION_API_URL=http://127.0.0.1:8000

# OpenAI extraction is optional. Turn this on when you want the LLM to identify
# supplier/vendor/bidder names before redaction.
USE_OPENAI_EXTRACTION=false
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Local OCR. Install Tesseract separately, then set TESSERACT_CMD if tesseract.exe
# is not available on PATH.
USE_TESSERACT_OCR=true
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
OCR_MODE=auto
OCR_DPI=220
OCR_MIN_CONFIDENCE=45
NATIVE_TEXT_MIN_CHARS=80

# Optional cloud OCR fallback.
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Image/logo redaction defaults.
REDACT_ALL_IMAGES=false
REDACT_HEADER_FOOTER_IMAGES=true
